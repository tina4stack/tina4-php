/**
 * Generate a Twig form template with typed inputs and form_token.
 *
 * tina4php generate form Product
 * tina4php generate form Product --fields "name:string,price:float"
 */
function generateForm(string $name, array $flags): void
{
    global $INPUT_TYPE_MAP;
    $fields = parseFields($flags['fields'] ?? '');
    $table = tableNameFromClass($name);
    $routeName = $table . 's';

    $dir = 'src/templates/forms';
    @mkdir($dir, 0755, true);
    $path = "{$dir}/{$table}.twig";
    if (file_exists($path)) {
        echo "  File already exists: {$path}\n";
        return;
    }

    // Build form fields
    $fieldHtml = '';
    $fieldList = !empty($fields) ? $fields : [['name', 'string']];
    foreach ($fieldList as [$fname, $ftype]) {
        $itype = $INPUT_TYPE_MAP[$ftype] ?? 'text';
        $label = ucwords(str_replace('_', ' ', $fname));
        $step = in_array($ftype, ['float', 'numeric', 'decimal']) ? ' step="0.01"' : '';

        if ($itype === 'textarea') {
            $fieldHtml .= <<<TWIG
    <div class="form-group mb-3">
        <label for="{$fname}">{$label}</label>
        <textarea id="{$fname}" name="{$fname}" class="form-control" rows="4" placeholder="{$label}">{{ item.{$fname} }}</textarea>
    </div>

TWIG;
        } elseif ($itype === 'checkbox') {
            $fieldHtml .= <<<TWIG
    <div class="form-group mb-3">
        <label>
            <input type="checkbox" id="{$fname}" name="{$fname}" value="1" {% if item.{$fname} %}checked{% endif %}>
            {$label}
        </label>
    </div>

TWIG;
        } else {
            $fieldHtml .= <<<TWIG
    <div class="form-group mb-3">
        <label for="{$fname}">{$label}</label>
        <input type="{$itype}" id="{$fname}" name="{$fname}" class="form-control"{$step} value="{{ item.{$fname} }}" placeholder="{$label}">
    </div>

TWIG;
        }
    }

    $content = <<<TWIG
{% extends "base.twig" %}
{% block title %}{$name} {% if item.id %}Edit{% else %}Create{% endif %}{% endblock %}
{% block content %}
<div class="container mt-4">
    <h1>{% if item.id %}Edit {$name}{% else %}Create {$name}{% endif %}</h1>
    <form method="post" action="/api/{$routeName}{% if item.id %}/{{ item.id }}{% endif %}">
        {{ form_token() }}
{$fieldHtml}    <button type="submit" class="btn btn-primary">
        {% if item.id %}Update{% else %}Create{% endif %}
    </button>
    <a href="/api/{$routeName}" class="btn btn-secondary">Cancel</a>
    </form>
</div>
{% endblock %}

TWIG;

    file_put_contents($path, $content);
    echo "  Created {$path}\n";
}


/**
 * Generate list + detail view templates.
 *
 * tina4php generate view Product
 * tina4php generate view Product --fields "name:string,price:float"
 */
function generateView(string $name, array $flags): void
{
    $fields = parseFields($flags['fields'] ?? '');
    $table = tableNameFromClass($name);
    $routeName = $table . 's';

    $dir = 'src/templates/pages';
    @mkdir($dir, 0755, true);

    $cols = !empty($fields) ? array_map(fn($f) => $f[0], $fields) : ['name'];

    // List view
    $listPath = "{$dir}/{$routeName}.twig";
    if (!file_exists($listPath)) {
        $th = implode("\n                ", array_map(fn($c) => '<th>' . ucwords(str_replace('_', ' ', $c)) . '</th>', $cols));
        $td = implode("\n                ", array_map(fn($c) => '<td>{{ item.' . $c . ' }}</td>', $cols));

        $listContent = <<<TWIG
{% extends "base.twig" %}
{% block title %}{$name}s{% endblock %}
{% block content %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>{$name}s</h1>
        <a href="/{$routeName}/create" class="btn btn-primary">Add {$name}</a>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                {$th}
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for item in items %}
            <tr>
                <td>{{ item.id }}</td>
                {$td}
                <td>
                    <a href="/{$routeName}/{{ item.id }}" class="btn btn-sm btn-primary">View</a>
                    <a href="/{$routeName}/{{ item.id }}/edit" class="btn btn-sm btn-secondary">Edit</a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}

TWIG;
        file_put_contents($listPath, $listContent);
        echo "  Created {$listPath}\n";
    }

    // Detail view
    $detailPath = "{$dir}/{$table}.twig";
    if (!file_exists($detailPath)) {
        $detailFields = implode("\n", array_map(fn($c) =>
            '    <div class="mb-3"><strong>' . ucwords(str_replace('_', ' ', $c)) . ':</strong> {{ item.' . $c . ' }}</div>',
            $cols
        ));

        $detailContent = <<<TWIG
{% extends "base.twig" %}
{% block title %}{$name} Detail{% endblock %}
{% block content %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>{$name} #{{ item.id }}</h1>
        <div>
            <a href="/{$routeName}/{{ item.id }}/edit" class="btn btn-secondary">Edit</a>
            <a href="/{$routeName}" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>
{$detailFields}
</div>
{% endblock %}

TWIG;
        file_put_contents($detailPath, $detailContent);
        echo "  Created {$detailPath}\n";
    }
}


/**
 * Generate authentication scaffolding: User model, auth routes, login/register templates, test.
 *
 * tina4php generate auth
 */
function generateAuth(string $name, array $flags, array $fieldTypeMap): void
{
    echo "\n  Generating authentication scaffolding...\n\n";

    // 1. User model + migration
    generateModel('User', ['fields' => 'email:string,password:string,role:string'], $fieldTypeMap);

    // 2. Auth routes
    $dir = 'src/routes';
    @mkdir($dir, 0755, true);
    $authPath = "{$dir}/auth.php";
    if (!file_exists($authPath)) {
        $content = <<<'PHP'
<?php

/**
 * @description Register a new user
 * @tags auth
 */
Router::post("/api/auth/register", function (\Tina4\Request $request, \Tina4\Response $response) {
    try {
        $body = (array)$request->body;
        $email = $body['email'] ?? '';
        $password = $body['password'] ?? '';

        if (empty($email) || empty($password)) {
            return $response(["error" => "Email and password required"], 400);
        }

        // Check if user exists
        $existing = new User();
        if ($existing->load("email = ?", [$email])) {
            return $response(["error" => "Email already registered"], 409);
        }

        // Create user with hashed password
        $user = new User();
        $user->email = $email;
        $user->password = \Tina4\Auth::hashPassword($password);
        $user->role = 'user';
        $user->save();

        return $response(["message" => "Registered", "id" => $user->id], 201);
    } catch (\Throwable $e) {
        \Tina4\Debug::message($e->getMessage(), TINA4_LOG_ERROR);
        return $response(["error" => "Registration failed"], 500);
    }
})->noCache();

/**
 * @description Login and receive JWT token
 * @tags auth
 */
Router::post("/api/auth/login", function (\Tina4\Request $request, \Tina4\Response $response) {
    try {
        $body = (array)$request->body;
        $email = $body['email'] ?? '';
        $password = $body['password'] ?? '';

        $user = new User();
        if (!$user->load("email = ?", [$email])) {
            return $response(["error" => "Invalid credentials"], 401);
        }

        if (!\Tina4\Auth::checkPassword($password, $user->password)) {
            return $response(["error" => "Invalid credentials"], 401);
        }

        $secret = getenv('SECRET') ?: 'change-me-in-production';
        $token = \Tina4\Auth::getToken(
            ["user_id" => $user->id, "email" => $user->email, "role" => $user->role],
            $secret
        );
        return $response(["token" => $token], 200);
    } catch (\Throwable $e) {
        \Tina4\Debug::message($e->getMessage(), TINA4_LOG_ERROR);
        return $response(["error" => "Login failed"], 500);
    }
})->noCache();

/**
 * @description Get current user profile
 * @tags auth
 */
Router::get("/api/auth/me", function (\Tina4\Request $request, \Tina4\Response $response) {
    try {
        $authHeader = $request->getHeader("Authorization");
        if (empty($authHeader)) {
            return $response(["error" => "Unauthorized"], 401);
        }

        $token = str_replace("Bearer ", "", $authHeader);
        $secret = getenv('SECRET') ?: 'change-me-in-production';
        $payload = \Tina4\Auth::validToken($token, $secret);

        if ($payload === null) {
            return $response(["error" => "Invalid token"], 401);
        }

        $user = new User();
        if (!$user->load("id = ?", [$payload['user_id'] ?? 0])) {
            return $response(["error" => "User not found"], 404);
        }

        return $response(["id" => $user->id, "email" => $user->email, "role" => $user->role], 200);
    } catch (\Throwable $e) {
        \Tina4\Debug::message($e->getMessage(), TINA4_LOG_ERROR);
        return $response(["error" => "Failed to get profile"], 500);
    }
})->secure();
PHP;

        file_put_contents($authPath, $content);
        echo "  Created {$authPath}\n";
    }

    // 3. Login template
    $formsDir = 'src/templates/forms';
    @mkdir($formsDir, 0755, true);
    $loginPath = "{$formsDir}/login.twig";
    if (!file_exists($loginPath)) {
        $loginContent = <<<'TWIG'
{% extends "base.twig" %}
{% block title %}Login{% endblock %}
{% block content %}
<div class="container mt-4" style="max-width:400px">
    <h1>Login</h1>
    <form method="post" action="/api/auth/login">
        {{ form_token() }}
        <div class="form-group mb-3">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required>
        </div>
        <div class="form-group mb-3">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" class="form-control" placeholder="Password" required>
        </div>
        <button type="submit" class="btn btn-primary w-100">Login</button>
        <p class="mt-3 text-center"><a href="/register">Create an account</a></p>
    </form>
</div>
{% endblock %}
TWIG;
        file_put_contents($loginPath, $loginContent);
        echo "  Created {$loginPath}\n";
    }

    // 4. Register template
    $registerPath = "{$formsDir}/register.twig";
    if (!file_exists($registerPath)) {
        $registerContent = <<<'TWIG'
{% extends "base.twig" %}
{% block title %}Register{% endblock %}
{% block content %}
<div class="container mt-4" style="max-width:400px">
    <h1>Register</h1>
    <form method="post" action="/api/auth/register">
        {{ form_token() }}
        <div class="form-group mb-3">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required>
        </div>
        <div class="form-group mb-3">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" class="form-control" placeholder="Password" minlength="8" required>
        </div>
        <button type="submit" class="btn btn-primary w-100">Register</button>
        <p class="mt-3 text-center"><a href="/login">Already have an account?</a></p>
    </form>
</div>
{% endblock %}
TWIG;
        file_put_contents($registerPath, $registerContent);
        echo "  Created {$registerPath}\n";
    }

    // 5. Auth test
    generateTest('auth', ['model' => 'User']);

    echo "\n  Authentication scaffolding complete.\n";
    echo "  Run: tina4php migrate\n";
    echo "  POST /api/auth/register  -- create account\n";
    echo "  POST /api/auth/login     -- get JWT token\n";
    echo "  GET  /api/auth/me        -- get profile (requires token)\n";
}
