#!/usr/bin/env php
<?php
/**
 * Tina4 PHP CLI — v3
 *
 * Usage:
 *   tina4php init [dir]             Scaffold a new project
 *   tina4php serve [host:port|port]  Start dev server (default: 0.0.0.0:7146)
 *   tina4php start [host:port|port] Alias for serve
 *   tina4php migrate                Run pending migrations
 *   tina4php migrate:create <desc>  Create a migration file
 *   tina4php migrate:rollback       Rollback last batch
 *   tina4php migrate:status         Show migration status
 *   tina4php seed                   Run seeders from src/seeds/
 *   tina4php routes                 List all registered routes
 *   tina4php test                   Run test suite
 *   tina4php build                  Build distributable package
 *   tina4php generate <what> <name>  Generate scaffolding (model, route, migration, middleware)
 *   tina4php ai [--all]             Detect AI tools and install context
 *   tina4php help                   Show this help
 */

// ── Resolve paths ──
$cwd = getcwd();

// Find autoloader: CWD first, then relative to this binary
$autoloadPaths = [
    $cwd . '/vendor/autoload.php',
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../autoload.php',
];

$autoloaded = false;
foreach ($autoloadPaths as $autoloadFile) {
    if (file_exists($autoloadFile)) {
        require_once $autoloadFile;
        $autoloaded = true;
        break;
    }
}

// Constants are auto-loaded via composer "files" autoload — no manual require needed

// Framework root (where the Tina4 source lives)
$frameworkRoot = realpath(__DIR__ . '/..');

// ── Port/host resolution ──
// Priority: CLI arg > ENV var > default
// Extracted as a function so it can be unit-tested.
function resolveHostPort(?string $cliArg = null): array
{
    $defaultHost = '0.0.0.0';
    $defaultPort = '7146';

    $host = null;
    $port = null;

    // 1. CLI argument (highest priority)
    if ($cliArg !== null && $cliArg !== '') {
        if (str_contains($cliArg, ':')) {
            [$host, $port] = explode(':', $cliArg, 2);
        } else {
            $port = $cliArg;
        }
    }

    // 2. ENV vars (fill in anything not set by CLI)
    if ($host === null) {
        $envHost = getenv('HOST');
        if ($envHost !== false && $envHost !== '') {
            $host = $envHost;
        }
    }
    if ($port === null) {
        $envPort = getenv('TINA4_PORT') ?: getenv('PORT');
        if ($envPort !== false && $envPort !== '') {
            $port = $envPort;
        }
    }

    // 3. Defaults
    $host = $host ?? $defaultHost;
    $port = $port ?? $defaultPort;

    return [$host, $port];
}

// ── Parse command ──
$command = $argv[1] ?? 'help';
$args = array_slice($argv, 2);

switch ($command) {

    // ────────────────────────────────────────────
    // INIT — Scaffold a new project
    // ────────────────────────────────────────────
    case 'init':
        $targetDir = isset($args[0]) ? realpath($args[0]) ?: $args[0] : $cwd;

        // Create target if it doesn't exist
        if (!is_dir($targetDir)) {
            mkdir($targetDir, 0755, true);
        }
        $targetDir = realpath($targetDir) . DIRECTORY_SEPARATOR;

        // Create directories
        $dirs = [
            'src/routes', 'src/templates', 'src/templates/errors',
            'src/orm', 'src/public', 'src/public/css', 'src/public/js',
            'src/scss', 'src/services', 'src/app', 'src/locales', 'src/seeds',
            'migrations', 'logs',
        ];
        foreach ($dirs as $dir) {
            $full = $targetDir . str_replace('/', DIRECTORY_SEPARATOR, $dir);
            if (!is_dir($full)) {
                mkdir($full, 0755, true);
                echo "  Created {$dir}/\n";
            }
        }

        // Create index.php
        if (!file_exists($targetDir . 'index.php')) {
            $indexContent = <<<'PHP'
<?php
require_once "./vendor/autoload.php";

$app = new \Tina4\App(basePath: __DIR__);
$app->handle();
PHP;
            file_put_contents($targetDir . 'index.php', $indexContent);
            echo "  Created index.php\n";
        }

        // Create composer.json
        if (!file_exists($targetDir . 'composer.json')) {
            $composerContent = json_encode([
                'name' => 'tina4/my-project',
                'require' => [
                    'tina4stack/tina4-php' => '^3.0',
                ],
                'autoload' => [
                    'psr-4' => [
                        '' => 'src/app/',
                    ],
                ],
            ], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n";
            file_put_contents($targetDir . 'composer.json', $composerContent);
            echo "  Created composer.json\n";
        }

        // Create .env
        if (!file_exists($targetDir . '.env')) {
            file_put_contents($targetDir . '.env', "TINA4_DEBUG=true\nTINA4_DEBUG_LEVEL=ALL\n");
            echo "  Created .env\n";
        }

        // Create .gitignore
        if (!file_exists($targetDir . '.gitignore')) {
            file_put_contents($targetDir . '.gitignore', "vendor/\nlogs/\n*.db\n.env\nnode_modules/\n");
            echo "  Created .gitignore\n";
        }

        // Create Dockerfile
        if (!file_exists($targetDir . 'Dockerfile')) {
            $dockerfile = <<<'DOCKERFILE'
# Build stage
FROM php:8.4-cli AS build
WORKDIR /app

RUN apt-get update && apt-get install -y unzip git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer
COPY --from=mlocati/php-extension-installer /usr/bin/install-php-extensions /usr/bin/install-php-extensions
RUN install-php-extensions sqlite3 opcache

COPY composer.json composer.lock* ./
RUN composer install --no-dev --optimize-autoloader --no-scripts
COPY . .

# Runtime stage
FROM php:8.4-cli
WORKDIR /app

COPY --from=mlocati/php-extension-installer /usr/bin/install-php-extensions /usr/bin/install-php-extensions
RUN install-php-extensions sqlite3 opcache

COPY --from=build /app .

ENV HOST=0.0.0.0
ENV PORT=7146
EXPOSE 7146
CMD ["php", "bin/tina4php", "serve", "--host", "0.0.0.0", "--port", "7146"]
DOCKERFILE;
            file_put_contents($targetDir . 'Dockerfile', $dockerfile);
            echo "  Created Dockerfile\n";
        }

        // Create .dockerignore
        if (!file_exists($targetDir . '.dockerignore')) {
            file_put_contents($targetDir . '.dockerignore', "vendor\n.git\n.claude\n.env\n*.log\ntests\ntmp\n");
            echo "  Created .dockerignore\n";
        }

        echo "\nProject initialized in {$targetDir}\n";
        echo "  cd {$targetDir}\n";
        echo "  composer install\n";
        echo "  vendor/bin/tina4php serve\n";
        break;

    // ────────────────────────────────────────────
    // SERVE / START — Start PHP built-in server
    // ────────────────────────────────────────────
    case 'serve':
    case 'start':
        // Load .env BEFORE port resolution so TINA4_PORT from .env is visible to getenv()
        $envFile = $cwd . DIRECTORY_SEPARATOR . '.env';
        if (is_file($envFile) && class_exists('\Tina4\DotEnv')) {
            \Tina4\DotEnv::loadEnv($envFile);
        }

        // Parse --port=XXXX / --host=XXXX flags from $args (highest priority after explicit positional arg)
        $flagPort = null;
        $flagHost = null;
        $positionalArg = null;
        foreach ($args as $arg) {
            if (preg_match('/^--port[=:](\S+)$/', $arg, $m)) {
                $flagPort = $m[1];
            } elseif (preg_match('/^--host[=:](\S+)$/', $arg, $m)) {
                $flagHost = $m[1];
            } elseif (!str_starts_with($arg, '--') && $positionalArg === null) {
                $positionalArg = $arg;
            }
        }
        [$host, $port] = resolveHostPort($positionalArg);
        if ($flagPort !== null) {
            $port = $flagPort;
        }
        if ($flagHost !== null) {
            $host = $flagHost;
        }
        $port = (int)$port;

        // Find index.php
        if (file_exists($cwd . '/index.php')) {
            $docRoot = $cwd;
        } else {
            echo "Error: No index.php found in {$cwd}\n";
            echo "Run 'tina4php init' first.\n";
            exit(1);
        }

        // Only use colors when stdout is a TTY
        $isTty = function_exists('posix_isatty') ? posix_isatty(STDOUT) : (getenv('TERM') !== false);
        $color = $isTty ? "\e[35m" : "";
        $reset = $isTty ? "\e[0m" : "";

        $isDebug = class_exists('\Tina4\DotEnv') ? \Tina4\DotEnv::isTruthy(\Tina4\DotEnv::getEnv('TINA4_DEBUG', 'false')) : false;
        $logLevel = (class_exists('\Tina4\DotEnv') ? \Tina4\DotEnv::getEnv('TINA4_LOG_LEVEL', 'DEBUG') : 'DEBUG');

        // Detect server mode
        $serverName = 'tina4-server';
        $useFrankenPHP = false;

        if (!$isDebug) {
            // Check for FrankenPHP in production mode
            $frankenphp = trim(shell_exec('which frankenphp 2>/dev/null') ?? '');
            if (!empty($frankenphp)) {
                $serverName = 'frankenphp';
                $useFrankenPHP = true;
            }
        }

        // Bootstrap the application — include user's index.php if available so that
        // any initialisation code (DB setup, ORM binding, etc.) runs before the server
        // starts. handle() is CLI-safe and just calls start() without dispatching HTTP.
        if (file_exists($cwd . '/index.php')) {
            ob_start();
            include_once $cwd . '/index.php';
            ob_end_clean();
        } else {
            $app = new \Tina4\App(basePath: $cwd, development: $isDebug);
            $app->start();
        }
        $wsRoutes = \Tina4\Router::getWebSocketRoutes();
        $wsInfo = count($wsRoutes) > 0 ? ' (WebSocket: ' . count($wsRoutes) . ' routes)' : '';

        echo "{$color}
  ______ _             __ __
 /_  __/(_)___  ____ _/ // /
  / /  / / __ \\/ __ \`/ // /_
 / /  / / / / / /_/ /__  __/
/_/  /_/_/ /_/\\__,_/  /_/
{$reset}
  Tina4 PHP v" . \Tina4\App::VERSION . " — This is not a framework

  Server:    http://{$host}:{$port} ({$serverName}){$wsInfo}
  Swagger:   http://localhost:{$port}/swagger
  Dashboard: http://localhost:{$port}/__dev
  Debug:     " . ($isDebug ? 'ON' : 'OFF') . " (Log level: {$logLevel})
";

        if ($useFrankenPHP) {
            // FrankenPHP for production — natively supports WebSocket
            passthru("frankenphp php-server --listen :{$port} --root " . escapeshellarg($docRoot));
        } else {
            // Custom Tina4 server with HTTP + WebSocket support
            try {
                $server = new \Tina4\Server($host, $port);
                $server->start();
            } catch (\RuntimeException $e) {
                // Fallback to PHP built-in server (no WebSocket support)
                echo "  Warning: Custom server failed, falling back to php -S (no WebSocket support)\n";
                echo "  Reason: {$e->getMessage()}\n\n";

                $extraArgs = '';
                if (!$isDebug && (function_exists('opcache_get_status') || extension_loaded('Zend OPcache'))) {
                    $extraArgs = ' -d opcache.enable=1 -d opcache.enable_cli=1 -d opcache.jit=1255 -d opcache.jit_buffer_size=128M';
                }

                passthru("php{$extraArgs} -S {$host}:{$port} -t " . escapeshellarg($docRoot) . " " . escapeshellarg($docRoot . '/index.php'));
            }
        }
        break;

    // ────────────────────────────────────────────
    // MIGRATE — Run/create/rollback migrations
    // ────────────────────────────────────────────
    case 'migrate':
        if ($autoloaded && file_exists($cwd . '/index.php')) {
            // Load the project to get $DBA
            ob_start();
            include_once $cwd . '/index.php';
            ob_end_clean();
        }
        $migrationsDir = $cwd . '/migrations';
        if (!is_dir($migrationsDir)) {
            mkdir($migrationsDir, 0755, true);
        }
        if (class_exists('\Tina4\Migration')) {
            $migration = new \Tina4\Migration($migrationsDir);
            echo $migration->doMigration();
        } else {
            echo "Migration class not available.\n";
        }
        break;

    case 'migrate:create':
        $name = implode(' ', $args) ?: 'unnamed_migration';
        $migrationsDir = $cwd . '/migrations';
        if (!is_dir($migrationsDir)) {
            mkdir($migrationsDir, 0755, true);
        }
        if (class_exists('\Tina4\Migration')) {
            $migration = new \Tina4\Migration($migrationsDir);
            echo $migration->createMigration($name, "-- Write your migration SQL here\n");
        } else {
            echo "Migration class not available.\n";
        }
        break;

    case 'migrate:rollback':
        if ($autoloaded && file_exists($cwd . '/index.php')) {
            ob_start();
            include_once $cwd . '/index.php';
            ob_end_clean();
        }
        $migrationsDir = $cwd . '/migrations';
        if (!is_dir($migrationsDir)) {
            mkdir($migrationsDir, 0755, true);
        }
        if (class_exists('\Tina4\Migration')) {
            $migration = new \Tina4\Migration($migrationsDir);
            $result = $migration->rollback();

            if (empty($result['rolledBack']) && empty($result['errors'])) {
                echo "Nothing to rollback.\n";
            } else {
                foreach ($result['rolledBack'] as $name) {
                    echo "  Rolled back: {$name}\n";
                }
                foreach ($result['errors'] as $name => $error) {
                    echo "  Error rolling back {$name}: {$error}\n";
                }
                $count = count($result['rolledBack']);
                echo "\n{$count} migration(s) rolled back.\n";
            }
        } else {
            echo "Migration class not available.\n";
        }
        break;

    case 'migrate:status':
        if ($autoloaded && file_exists($cwd . '/index.php')) {
            ob_start();
            include_once $cwd . '/index.php';
            ob_end_clean();
        }
        $migrationsDir = $cwd . '/migrations';
        if (!is_dir($migrationsDir)) {
            mkdir($migrationsDir, 0755, true);
        }
        if (class_exists('\Tina4\Migration')) {
            $migration = new \Tina4\Migration($migrationsDir);
            $status = $migration->status();

            echo "Migration Status\n";
            echo str_repeat('=', 60) . "\n\n";

            if (!empty($status['completed'])) {
                echo "Completed:\n";
                echo str_pad('  Migration', 45) . str_pad('Batch', 8) . "Applied At\n";
                echo "  " . str_repeat('-', 58) . "\n";
                foreach ($status['completed'] as $m) {
                    echo '  ' . str_pad($m['migration'], 43) . str_pad((string)$m['batch'], 8) . ($m['applied_at'] ?? '') . "\n";
                }
            } else {
                echo "Completed: (none)\n";
            }

            echo "\n";

            if (!empty($status['pending'])) {
                echo "Pending:\n";
                foreach ($status['pending'] as $name) {
                    echo "  {$name}\n";
                }
            } else {
                echo "Pending: (none)\n";
            }

            echo "\n" . count($status['completed']) . " completed, " . count($status['pending']) . " pending.\n";
        } else {
            echo "Migration class not available.\n";
        }
        break;

    // ────────────────────────────────────────────
    // ROUTES — List registered routes
    // ────────────────────────────────────────────
    case 'routes':
        // Load the project
        if (file_exists($cwd . '/index.php')) {
            ob_start();
            include_once $cwd . '/index.php';
            ob_end_clean();
        }
        if (class_exists('\Tina4\Router')) {
            $routes = \Tina4\Router::list();
            echo str_pad('METHOD', 8) . str_pad('PATH', 40) . "FLAGS\n";
            echo str_repeat('-', 60) . "\n";
            foreach ($routes as $r) {
                $flags = [];
                if ($r['cache'] ?? false) $flags[] = 'CACHE';
                if ($r['secure'] ?? false) $flags[] = 'AUTH';
                $flagStr = $flags ? '[' . implode(', ', $flags) . ']' : '';
                echo str_pad($r['method'], 8) . str_pad($r['pattern'], 40) . $flagStr . "\n";
            }
            echo str_repeat('-', 60) . "\n";
            echo "Total: " . count($routes) . " routes\n";
        }
        break;

    // ────────────────────────────────────────────
    // TEST — Run tests
    // ────────────────────────────────────────────
    case 'test':
        if (file_exists($cwd . '/tests/test_v3_smoke.php')) {
            passthru('php ' . escapeshellarg($cwd . '/tests/test_v3_smoke.php'));
        } elseif (file_exists($cwd . '/vendor/bin/phpunit')) {
            passthru($cwd . '/vendor/bin/phpunit tests --verbose --color');
        } else {
            echo "No test runner found. Install phpunit or create tests/test_v3_smoke.php\n";
        }
        break;

    // ────────────────────────────────────────────
    // SEED — Run seeders
    // ────────────────────────────────────────────
    case 'seed':
        $seedDir = $cwd . '/src/seeds';
        if (!is_dir($seedDir)) {
            echo "No seeds directory found at src/seeds/\n";
            break;
        }
        $seeds = glob($seedDir . '/*.php');
        if (empty($seeds)) {
            echo "No seed files found in src/seeds/\n";
        }
        foreach ($seeds as $seedFile) {
            echo "Running " . basename($seedFile) . "...\n";
            include $seedFile;
        }
        break;

    // ────────────────────────────────────────────
    // BUILD — Build distributable
    // ────────────────────────────────────────────
    case 'build':
        echo "Build not yet implemented in v3.\n";
        break;

    // ────────────────────────────────────────────
    // AI — Install AI context files
    // ────────────────────────────────────────────
    case 'generate':
        $what = $args[0] ?? null;
        $genName = $args[1] ?? null;
        if (!$what || !$genName) {
            echo "Usage: tina4php generate <what> <name>\n";
            echo "  Generators: model, route, migration, middleware\n";
            exit(1);
        }
        switch ($what) {
            case 'model':
                $dir = 'src/orm';
                @mkdir($dir, 0755, true);
                $path = "$dir/$genName.php";
                if (file_exists($path)) { echo "  File already exists: $path\n"; exit(1); }
                file_put_contents($path, "<?php\n\nclass $genName extends \\Tina4\\ORM {\n    public ?int \$id = null;\n    public string \$name = '';\n    public string \$email = '';\n}\n");
                echo "  Created $path\n";
                break;
            case 'route':
                $routePath = ltrim($genName, '/');
                $dir = "src/routes/$routePath";
                @mkdir($dir, 0755, true);
                $path = rtrim($dir, '/') . '.php';
                if (file_exists($path)) { echo "  File already exists: $path\n"; exit(1); }
                $content = "<?php\n\n";
                $content .= "\\Tina4\\Get::add(\"/$routePath\", function (\\Tina4\\Request \$request, \\Tina4\\Response \$response) {\n    return \$response->json([\"data\" => []]);\n});\n\n";
                $content .= "\\Tina4\\Get::add(\"/$routePath/{id}\", function (\\Tina4\\Request \$request, \\Tina4\\Response \$response) {\n    return \$response->json([\"data\" => []]);\n});\n\n";
                $content .= "\\Tina4\\Post::add(\"/$routePath\", function (\\Tina4\\Request \$request, \\Tina4\\Response \$response) {\n    return \$response->json([\"message\" => \"created\"], 201);\n});\n\n";
                $content .= "\\Tina4\\Put::add(\"/$routePath/{id}\", function (\\Tina4\\Request \$request, \\Tina4\\Response \$response) {\n    return \$response->json([\"message\" => \"updated\"]);\n});\n\n";
                $content .= "\\Tina4\\Delete::add(\"/$routePath/{id}\", function (\\Tina4\\Request \$request, \\Tina4\\Response \$response) {\n    return \$response->json([\"message\" => \"deleted\"]);\n});\n";
                file_put_contents($path, $content);
                echo "  Created $path\n";
                break;
            case 'migration':
                $dir = 'migrations';
                @mkdir($dir, 0755, true);
                $timestamp = date('YmdHis');
                $table = preg_replace('/^create_/', '', $genName);
                if (!str_ends_with($table, 's')) {
                    $table = str_ends_with($table, 'y') ? substr($table, 0, -1) . 'ies' : $table . 's';
                }
                $fileName = "{$timestamp}_{$genName}.sql";
                $path = "$dir/$fileName";
                $now = date('Y-m-d H:i:s');
                file_put_contents($path, "-- Migration: $genName\n-- Created: $now\n\nCREATE TABLE $table (\n    id INTEGER PRIMARY KEY AUTOINCREMENT,\n    name TEXT NOT NULL,\n    email TEXT NOT NULL,\n    created_at DATETIME DEFAULT CURRENT_TIMESTAMP\n);\n");
                echo "  Created $path\n";
                break;
            case 'middleware':
                $dir = 'src/middleware';
                @mkdir($dir, 0755, true);
                $path = "$dir/$genName.php";
                if (file_exists($path)) { echo "  File already exists: $path\n"; exit(1); }
                file_put_contents($path, "<?php\n\nclass $genName extends \\Tina4\\Middleware {\n    public function process(\\Tina4\\Request \$request, \\Tina4\\Response \$response): ?\\Tina4\\Response {\n        \$auth = \$request->getHeader(\"Authorization\");\n        if (empty(\$auth)) {\n            return \$response->json([\"error\" => \"Unauthorized\"], 401);\n        }\n        return null;\n    }\n}\n");
                echo "  Created $path\n";
                break;
            default:
                echo "Unknown generator: $what\n";
                echo "  Available: model, route, migration, middleware\n";
                exit(1);
        }
        break;

    case 'ai':
        if (isset($args[0]) && strtolower($args[0]) === 'all') {
            \Tina4\AI::installAll($cwd);
        } else {
            $selection = \Tina4\AI::showMenu($cwd);
            if ($selection) {
                \Tina4\AI::installSelected($cwd, $selection);
            }
        }
        break;

    // ────────────────────────────────────────────
    // HELP
    // ────────────────────────────────────────────
    case 'help':
    case '--help':
    case '-h':
    default:
        echo "Tina4 PHP CLI v3\n\n";
        echo "Usage: tina4php <command> [options]\n\n";
        echo "Commands:\n";
        echo "  init [dir]              Scaffold a new project\n";
        echo "  serve [host:port|port]   Start dev server (default: 0.0.0.0:7146)\n";
        echo "  start [host:port|port]   Alias for serve\n";
        echo "  migrate                 Run pending migrations\n";
        echo "  migrate:create <desc>   Create a migration file\n";
        echo "  migrate:rollback        Rollback last batch\n";
        echo "  migrate:status          Show migration status\n";
        echo "  seed                    Run seeders from src/seeds/\n";
        echo "  routes                  List all registered routes\n";
        echo "  test                    Run test suite\n";
        echo "  build                   Build distributable package\n";
        echo "  generate <what> <name>  Generate scaffolding (model, route, migration, middleware)\n";
        echo "  ai [--all]              Detect AI tools and install context\n";
        echo "  help                    Show this help\n";
        break;
}
