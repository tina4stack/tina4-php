{
    "name": "tina4stack/tina4php",
    "description": "Tina4 PHP",
    "version": "3.0.0",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Tina4\\": "src/Tina4/",
            "Tina4\\Middleware\\": "src/Tina4/Middleware/",
            "Tina4\\Database\\": "src/Tina4/Database/"
        }
    },
    "require": {
        "php": ">=8.2",
        "ext-openssl": "*",
        "ext-json": "*"
    },
    "scripts": {
        "tina4php": "@php bin/tina4php",
        "tina4php-debug": "@php -dxdebug.mode=debug -dxdebug.client_host=host.docker.internal -dxdebug.client_port=9004 -dxdebug.start_with_request=yes bin/tina4php",
        "tina4service": "tina4service",
        "test": "@tina4php tests:run",
        "phplint": "vendor/bin/phplint",
        "watcher": "vendor/bin/php-watcher",
        "test:verbose": "@tina4php tests:verbose",
        "initialize": "@tina4php initialize:run",
        "initialise": "@tina4php initialize:run",
        "debug": "@tina4php-debug webservice:run",
        "begin": "@tina4php initialize:run",
        "start": "@tina4php webservice:run",
        "start-service": "@tina4service",
        "run-tests": "./vendor/bin/phpunit tests --verbose --color --log-junit=tests/junit.xml -v",
        "phpmetrics": "./vendor/bin/phpmetrics --report-html=phpmetrics --junit=tests/junit.xml ./Tina4",
        "lint": "@phplint --exclude=vendor"
    },
    "config": {
        "process-timeout": 0
    },
    "require-dev": {
        "phpunit/phpunit": "^10 || ^11"
    },
    "bin": [
        "bin/tina4php"
    ],
    "suggest": {
        "ext-sqlite3": "Required for SQLite3 database support",
        "ext-pdo": "Required for MySQL/PostgreSQL/MSSQL database support",
        "ext-curl": "Required for external API calls",
        "ext-fileinfo": "Required for file type detection",
        "ext-zip": "Required for ZIP file handling"
    }
}
