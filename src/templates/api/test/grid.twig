<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=yes">

    <link rel="stylesheet" href="/css/tina4.min.css">
    <script src="/js/tina4.min.js"></script>
    <script src="/js/frond.min.js"></script>
    <title>Test</title>
</head>

<body>
    <h3>Test</h3>
    <table id="testGrid" class="table table-striped table-bordered table-condensed" style="width:100%">
        <thead>
        <tr>
                            <th>Id</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                        <th>Options</th>
        </tr>
        </thead>
    </table>
    <script>
        var testGrid = null;
        $(document).ready(function () {
            testGrid = $('#testGrid').DataTable({
                dom: '<"row"<"col-md-6"B><"col-md-4"f><"col-md-2"l>><rtip>',
                ajax: {
                        url: '/api/test',
                        data: function (d) {
                            d.formToken = formToken;
                        }
                },
                columns: [
                                        {"data": "id"},
                                        {"data": "firstName"},
                                        {"data": "lastName"},
                                        {
                        "data": null,
                        "mRender": function (data, type, row) {
                            let html = '';
                            //loadForm parameters: api to retrieve modal form, target div id to load form to, row data, title of
                            html += '<button class="btn btn-primary small-button" onclick="showForm(\'edit\',\'/api/test/' + row.id + '?formToken={{ formToken ("/api/test") }}\')">Edit</button>';
                            html += ' <button class="btn btn-danger small-button" onclick="if (confirm(\'Delete  record ?\')) { showForm(\'delete\',\'/api/test/' + row.id + '?formToken={{ formToken ("/api/test") }}\');}">Del</button>';
                            return html;

                        },
                        "sClass": "text-right",
                        "searchable": false
                    }

                ],
                processing: true,
                serverSide: true,
                responsive: true,
                buttons: [
                    {
                        text: 'Create',
                        action: function (e, dt, node, config) {
                            let data = {};
                            showForm('create', '/api/test/form?formToken={{ formToken ("/api/test") }}');
                        }
                    },
                    'copy', 'excel', 'pdf', 'print'

                ]
            });
        });
    </script>
    <div id="form"></div>
    <div id="message"></div>
</body>
</html>
