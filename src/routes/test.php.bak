\Tina4\Post::add("/stripe/webhook", function(\Tina4\Response $response, \Tina4\Request $request){
    file_put_contents("./log/test.txt", print_r($request->headers, 1), FILE_APPEND);
    file_put_contents("./log/test.txt", $request->rawRequest, FILE_APPEND);
    $sections = explode(",", $request->headers["stripe-signature"]);
    $key = explode("=", $sections[0])[1];
    file_put_contents('./log/test.txt', hash_hmac('sha256', $key.".".file_get_contents("php://input"), 'whsec_8N5qx8O4yzDXDSrDek7gmXEIReEqMrLw'), FILE_APPEND);

});


