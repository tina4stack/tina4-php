DirectoryIndex index.php
RewriteEngine On

# Block sensitive files (.env, .htaccess, secrets/, src/ internals)
<FilesMatch "\.(env|htaccess|htpasswd)$">
    Require all denied
</FilesMatch>

# Uncomment the 3 lines below to force HTTPS (production only)
# RewriteCond %{HTTPS} !=on
# RewriteCond %{REQUEST_URI} !^/.well-known/ [NC]
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

# Serve existing files and directories directly (static assets, uploads)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else through the Tina4 front controller
RewriteRule ^(.*)$ index.php [QSA,L]

# Pass Authorization header to PHP (required for Bearer tokens under Apache)
SetEnvIf Authorization .+ HTTP_AUTHORIZATION=$0