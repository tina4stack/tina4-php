{% extends "base.twig" %}

{% block title %}{{ t("login") }}{% endblock %}

{% block content %}
    <div class="row">
        <div class="col"></div>
        <div class="col">
            <div class="card">
                <div class="card-body">
                    <h2>{{ t("login") }}</h2>
                    {% if error %}
                        <div class="alert alert-danger mb-3">{{ error }}</div>
                    {% endif %}
                    <form id="login-form" method="POST" action="/login">
                        {{ form_token() }}
                        <div class="mb-3">
                            <label for="login-email">{{ t("email") }}</label>
                            <input type="email" id="login-email" name="email" class="form-control" placeholder="you@example.com" required>
                        </div>
                        <div class="mb-3">
                            <label for="login-password">{{ t("password") }}</label>
                            <input type="password" id="login-password" name="password" class="form-control" placeholder="Your password" required>
                        </div>
                        <button type="submit" class="btn btn-primary">{{ t("login") }}</button>
                    </form>
                    <p class="mt-3 text-muted">{{ t("no_account") }} <a href="/register">{{ t("register") }}</a></p>
                </div>
            </div>
        </div>
        <div class="col"></div>
    </div>
{% endblock %}
